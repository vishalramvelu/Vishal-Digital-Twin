# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- OpenAI ---
OPEN_AI_KEY=sk-your-openai-api-key

# --- Outlook (Microsoft Graph) ---
# From Azure Portal: App registrations → Your app → Application (client) ID
OUTLOOK_CLIENT_ID=your-azure-client-id
# From Azure: Directory (tenant) ID
OUTLOOK_TENANT_ID=your-azure-tenant-id

# --- Google Calendar ---
# From Google Cloud Console: APIs & Services → Credentials → OAuth 2.0 Client
GOOG_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOG_CLIENT_SECRET=your-google-client-secret
# Optional: leave empty on first run; the app will open a browser to sign in and then save it here
GOOG_REFRESH_TOKEN=

# --- GitHub (for build-time repo fetching) ---
GITHUB_TOKEN=ghp_your-personal-access-token
